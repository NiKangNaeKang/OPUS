<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >

<mapper namespace="nknk.opus.project.member.model.mapper.MemberMapper">

    <select id="login" resultType="nknk.opus.project.member.model.dto.Member">
        SELECT 
            MEMBER_NO, 
            MEMBER_EMAIL, 
            MEMBER_PW, 
            AUTHOR_LEVEL,
            ENROLL_DATE,
            MEMBER_DEL_FL
        FROM "MEMBER"
        WHERE MEMBER_EMAIL = #{memberEmail}
        AND MEMBER_DEL_FL = 'N'
    </select>

</mapper>